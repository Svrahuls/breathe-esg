# Backend — copy to backend/.env and fill in values
SECRET_KEY=django-insecure-replace-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3
# For PostgreSQL: DATABASE_URL=postgres://user:password@localhost:5432/breathe_esg
CORS_ALLOW_ALL_ORIGINS=True

# Frontend — copy to frontend/.env.local
VITE_API_URL=http://localhost:8000
